{
  "name": "vitepress-plugin-obsidian",
  "type": "module",
  "version": "0.1.0",
  "description": "Support Obsidian-flavored Markdown syntax in your VitePress site.",
  "author": "pengzhanbo <q942450674@outlook.com> (https://github.com/pengzhanbo/)",
  "license": "MIT",
  "keywords": [
    "vitepress",
    "vitepress-plugin",
    "obsidian"
  ],
  "exports": {
    ".": "./dist/node/index.js"
  },
  "module": "./dist/node/index.js",
  "types": "./dist/node/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf --glob ./dist",
    "dev": "pnpm tsdown -w",
    "build": "pnpm tsdown",
    "tsdown": "tsdown --config-loader unrun"
  },
  "peerDependencies": {
    "vitepress": "^1.6.4 || ^2.0.0-alpha.17",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@pengzhanbo/utils": "catalog:prod",
    "@vueuse/core": "catalog:prod",
    "ansis": "catalog:prod",
    "gray-matter": "catalog:prod",
    "markdown-it": "catalog:dev",
    "tinyglobby": "catalog:prod",
    "vitepress-plugin-toolkit": "workspace:*",
    "vitepress-tuck": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
