{
  "name": "vitepress-plugin-codesandbox",
  "type": "module",
  "version": "0.1.0",
  "description": "Embed CodeSandbox in your VitePress site.",
  "author": "pengzhanbo <q942450674@outlook.com> (https://github.com/pengzhanbo/)",
  "license": "MIT",
  "keywords": [
    "vitepress",
    "vitepress-plugin",
    "codesandbox"
  ],
  "exports": {
    ".": "./dist/node/index.js",
    "./client": {
      "browser": "./dist/client/browser/index.js",
      "default": "./dist/client/ssr/index.js"
    },
    "./style.css": "./dist/client/style.css"
  },
  "module": "./dist/node/index.js",
  "types": "./dist/node/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf --glob ./dist",
    "dev": "pnpm tsdown:watch",
    "build": "pnpm tsdown",
    "tsdown": "tsdown --config-loader unrun",
    "tsdown:watch": "pnpm tsdown -w"
  },
  "peerDependencies": {
    "vitepress": "^1.6.4 || ^2.0.0-alpha.17",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "vitepress-plugin-toolkit": "workspace:*",
    "vitepress-tuck": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
