{
  "name": "vitepress-plugin-video",
  "type": "module",
  "version": "0.1.0",
  "description": "Embed videos from multiple platforms (Bilibili, YouTube, AcFun, and self-hosted) in your VitePress site.",
  "author": "pengzhanbo <q942450674@outlook.com> (https://github.com/pengzhanbo/)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pengzhanbo/vitepress-tuck.git",
    "directory": "packages/plugin-video"
  },
  "keywords": [
    "vitepress",
    "vitepress-plugin",
    "video",
    "bilibili",
    "youtube",
    "acfun",
    "artplayer"
  ],
  "exports": {
    ".": "./dist/node/index.js",
    "./client": {
      "browser": "./dist/client/browser/index.js",
      "default": "./dist/client/ssr/index.js"
    },
    "./style.css": "./dist/client/style.css"
  },
  "module": "./dist/node/index.js",
  "types": "./dist/node/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf --glob ./dist",
    "dev": "pnpm '/(tsdown|copy):watch/'",
    "build": "pnpm tsdown && pnpm copy",
    "copy": "cpx \"src/**/*.css\" dist",
    "copy:watch": "pnpm copy -w",
    "tsdown": "tsdown --config-loader unrun",
    "tsdown:watch": "pnpm tsdown -w"
  },
  "peerDependencies": {
    "dashjs": "catalog:peer",
    "hls.js": "catalog:peer",
    "mpegts.js": "catalog:peer",
    "vitepress": "^1.6.4 || ^2.0.0-alpha.17",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "dashjs": {
      "optional": true
    },
    "hls.js": {
      "optional": true
    },
    "mpegts.js": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@pengzhanbo/utils": "catalog:prod",
    "@vueuse/core": "catalog:prod",
    "ansis": "catalog:prod",
    "artplayer": "catalog:prod",
    "local-pkg": "catalog:prod",
    "vitepress-plugin-toolkit": "workspace:*",
    "vitepress-tuck": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
