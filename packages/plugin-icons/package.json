{
  "name": "vitepress-plugin-icons",
  "type": "module",
  "version": "0.10.0",
  "description": "Provide icons for vitepress with iconify / iconfont / fontAwesome.",
  "author": "pengzhanbo <q942450674@outlook.com> (https://github.com/pengzhanbo/)",
  "license": "MIT",
  "homepage": "https://tuck.pengzhanbo.cn/plugins/icons",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pengzhanbo/vitepress-tuck.git",
    "directory": "packages/plugin-icons"
  },
  "bugs": {
    "url": "https://github.com/pengzhanbo/vitepress-tuck/issues"
  },
  "keywords": [
    "vitepress",
    "vitepress-plugin",
    "icons",
    "iconify",
    "iconfont",
    "fontAwesome"
  ],
  "exports": {
    ".": "./dist/node/index.js",
    "./style.css": "./dist/client/style.css"
  },
  "module": "./dist/node/index.js",
  "types": "./dist/node/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf --glob ./dist",
    "dev": "pnpm '/(tsdown|copy):watch/'",
    "build": "pnpm tsdown && pnpm copy",
    "copy": "cpx \"src/**/*.css\" dist",
    "copy:watch": "pnpm copy -w",
    "tsdown": "tsdown --config-loader unrun",
    "tsdown:watch": "pnpm tsdown -w"
  },
  "peerDependencies": {
    "@iconify/json": "catalog:peer",
    "vitepress": "^1.6.4 || ^2.0.0-alpha.17",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@iconify/json": {
      "optional": true
    }
  },
  "dependencies": {
    "@pengzhanbo/utils": "catalog:prod",
    "unplugin-icons": "catalog:prod",
    "vitepress-plugin-toolkit": "workspace:*",
    "vitepress-tuck": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
